{
  "name": "@ensemble-edge/workspace",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "packages/guest/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "tsc --build",
    "test": "vitest run",
    "typecheck": "tsc --build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "changeset": "changeset",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "prettier": "^3.2.5",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.2"
  },
  "license": "MIT"
}
