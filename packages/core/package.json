{
  "name": "@ensemble-edge/core",
  "version": "0.0.1",
  "type": "module",
  "description": "Ensemble Workspace engine — shell, gateway, and services",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./shell": {
      "types": "./src/shell/index.tsx",
      "import": "./src/shell/index.tsx"
    },
    "./types": {
      "types": "./src/types.ts",
      "import": "./src/types.ts"
    },
    "./mode": {
      "types": "./src/mode/index.ts",
      "import": "./src/mode/index.ts"
    },
    "./mode/define-config": {
      "types": "./src/mode/define-config.ts",
      "import": "./src/mode/define-config.ts"
    },
    "./services/auth": {
      "types": "./src/services/auth.ts",
      "import": "./src/services/auth.ts"
    },
    "./utils/jwt": {
      "types": "./src/utils/jwt.ts",
      "import": "./src/utils/jwt.ts"
    },
    "./utils/password": {
      "types": "./src/utils/password.ts",
      "import": "./src/utils/password.ts"
    },
    "./utils/cookies": {
      "types": "./src/utils/cookies.ts",
      "import": "./src/utils/cookies.ts"
    },
    "./middleware/auth": {
      "types": "./src/middleware/auth.ts",
      "import": "./src/middleware/auth.ts"
    },
    "./middleware/cloud-auth": {
      "types": "./src/middleware/cloud-auth.ts",
      "import": "./src/middleware/cloud-auth.ts"
    },
    "./routes/auth": {
      "types": "./src/routes/auth.ts",
      "import": "./src/routes/auth.ts"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "dev": "npm run build:shell && wrangler dev --local",
    "dev:types": "tsc --watch",
    "dev:shell": "node build.js --watch",
    "build": "npm run build:shell && tsc",
    "build:shell": "npm run build:css && node build.js",
    "build:css": "npx tailwindcss -i ./src/shell/styles/globals.css -o ./dist/shell/shell.css --minify",
    "build:shell:prod": "npm run build:css && node build.js --prod",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "deploy": "npm run build:shell:prod && wrangler deploy"
  },
  "dependencies": {
    "@ensemble-edge/ui": "workspace:*",
    "@preact/signals-react": "^2.0.0",
    "better-sqlite3": "^12.8.0",
    "hono": "^4.0.0",
    "jose": "^5.0.0",
    "lucide-react": "^0.469.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240117.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "bun": "^1.3.11",
    "esbuild": "^0.27.4",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.4.0",
    "wrangler": "^3.0.0"
  },
  "peerDependencies": {
    "@cloudflare/workers-types": "^4.0.0"
  },
  "license": "MIT"
}
