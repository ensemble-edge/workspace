{
  "name": "@ensemble-edge/shell",
  "version": "0.1.0",
  "description": "Ensemble workspace shell — React SPA with shadcn/ui",
  "type": "module",
  "main": "./dist/shell.js",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./assets": "./dist/assets.js",
    "./dist/*": "./dist/*"
  },
  "scripts": {
    "dev": "node build.js --watch",
    "build": "node build.js",
    "build:css": "npx tailwindcss -i ./src/styles/globals.css -o ./dist/shell.css --minify",
    "build:all": "npm run build:css && npm run build && node scripts/generate-assets.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ensemble-edge/ui": "workspace:*",
    "@preact/signals-react": "^2.0.0",
    "lucide-react": "^0.378.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "esbuild": "^0.25.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.0"
  },
  "files": [
    "src",
    "dist"
  ],
  "license": "MIT"
}
