{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  },
  "exclude": ["node_modules", "dist", "templates"],
  "references": [
    { "path": "packages/core" },
    { "path": "packages/sdk" },
    { "path": "packages/ui" },
    { "path": "packages/cli" },
    { "path": "packages/guest/core" },
    { "path": "packages/guest/cloudflare" }
  ]
}
